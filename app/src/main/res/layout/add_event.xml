<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mainbg"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/applogoplain"/>
        <TextView
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:fontFamily="@font/michroma"
            android:textSize="25sp"
            android:layout_gravity="center" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/y2026"
            android:fontFamily="serif"
            android:textSize="35sp"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="end"/>
    </LinearLayout>

    <TextView
        android:id="@+id/addEventPickedDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="30sp"
        android:text="Month Day"
        android:textSize="40sp"
        android:fontFamily="serif"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:padding="5dp">
        <EditText
            android:id="@+id/addEventTitle"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:hint=" Event Title"
            android:textSize="20sp"
            android:inputType="text"
            android:textColor="@color/black"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:padding="5dp">
        <EditText
            android:id="@+id/addEventTime"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:hint=" 00:00 AM/PM"
            android:textSize="20sp"
            android:inputType="text"
            android:textColor="@color/black"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:padding="5dp">
        <EditText
            android:id="@+id/addEventLocation"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:hint=" Location"
            android:textSize="20sp"
            android:inputType="text"
            android:textColor="@color/black"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:padding="5dp">
        <EditText
            android:id="@+id/addEventNotes"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:hint=" Notes"
            android:textSize="20sp"
            android:inputType="text"
            android:textColor="@color/black"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">
     <Button
            android:id="@+id/addEventReturn"
            android:layout_width="150dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="40dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/btnReturn"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#091726"
            app:backgroundTint="@null"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
    <Button
            android:id="@+id/addEventSubmit"
            android:layout_width="150dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="40dp"
            android:fontFamily="@font/poppins_medium"
            android:text="SUBMIT"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#091726"
            app:backgroundTint="@null"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
    </LinearLayout>
</LinearLayout>