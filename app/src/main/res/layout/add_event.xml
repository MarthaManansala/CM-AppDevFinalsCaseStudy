<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/mainbg"
    android:padding="16dp">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/applogoplain" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:fontFamily="@font/michroma"
            android:paddingStart="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/y2026"
            android:textSize="28sp"
            android:fontFamily="serif"/>
    </LinearLayout>

    <!-- DATE -->
    <TextView
        android:id="@+id/addEventPickedDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="20dp"
        android:text="Month Day"
        android:textSize="34sp"
        android:fontFamily="serif"
        android:gravity="center" />

    <!-- INPUT FIELD TEMPLATE -->
    <!-- TITLE -->
    <EditText
        android:id="@+id/addEventTitle"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:hint="Event Title"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="@drawable/edittext_bg"
        android:fontFamily="@font/poppins"
        android:textColor="@color/black" />

    <!-- TIME -->
    <EditText
        android:id="@+id/addEventTime"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:hint="00:00 AM/PM"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="@drawable/edittext_bg"
        android:fontFamily="@font/poppins"
        android:textColor="@color/black" />

    <!-- LOCATION -->
    <EditText
        android:id="@+id/addEventLocation"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="16dp"
        android:hint="Location"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="@drawable/edittext_bg"
        android:fontFamily="@font/poppins"
        android:textColor="@color/black" />

    <!-- NOTES -->
    <EditText
        android:id="@+id/addEventNotes"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:hint="Notes"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="@drawable/edittext_bg"
        android:fontFamily="@font/poppins"
        android:textColor="@color/black"
        android:gravity="top" />

    <!-- BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/addEventReturn"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="@string/btnReturn"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#555555"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/addEventSubmit"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="SUBMIT"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#091726"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>