<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".SetOfButtonsMarch"
    android:background="@drawable/mainbg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/applogoplain"/>
        <TextView
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:fontFamily="@font/michroma"
            android:textSize="25sp"
            android:layout_gravity="center" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/y2026"
            android:layout_weight="1"
            android:fontFamily="serif"
            android:textSize="35sp"
            android:layout_gravity="bottom"
            android:gravity="end"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="30dp"
        android:gravity="center">
        <TextView
            android:id="@+id/MarchSelectedDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp"
            android:text="@string/mMarch"
            android:textSize="40sp"
            android:fontFamily="serif"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnAddEventMarch"
            android:layout_width="250dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/btnAddEvent"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#091726"
            app:backgroundTint="@null"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button
            android:id="@+id/btnViewEventMarch"
            android:layout_width="250dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/btnViewEvents"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#091726"
            app:backgroundTint="@null"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
        <Button
            android:id="@+id/btnEditEventMarch"
            android:layout_width="250dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/btnEditEvent"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#091726"
            app:backgroundTint="@null"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
        <Button
            android:id="@+id/btnDeleteEventMarch"
            android:layout_width="250dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/btnDeleteEvent"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#091726"
            app:backgroundTint="@null"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
        <Button
            android:id="@+id/btnReturnMarch"
            android:layout_width="250dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/btnReturn"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#091726"
            app:backgroundTint="@null"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
</LinearLayout>

</LinearLayout>