<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@drawable/mainbg"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/applogoplain"/>
        <TextView
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:fontFamily="@font/michroma"
            android:textSize="25sp"
            android:layout_gravity="center" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/y2026"
            android:fontFamily="serif"
            android:textSize="35sp"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="end"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="30sp"
        android:text="@string/mApril"
        android:textSize="40sp"
        android:fontFamily="serif"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="25dp"
        android:gravity="center"
        android:orientation="horizontal">
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:layout_marginEnd="5sp" android:text="@string/Sunday" android:textSize="20sp" android:gravity="center" android:layout_weight="1"/>
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:layout_marginEnd="5sp" android:text="@string/Monday" android:textSize="20sp" android:gravity="center" android:layout_weight="1"/>
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:layout_marginEnd="5sp" android:text="@string/Tuesday" android:textSize="20sp" android:gravity="center" android:layout_weight="1"/>
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="@string/Wednesday" android:textSize="20sp" android:gravity="center" android:layout_weight="1"/>
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:layout_marginStart="5sp" android:text="@string/Thursday" android:textSize="20sp" android:gravity="center" android:layout_weight="1"/>
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:layout_marginStart="5sp" android:text="@string/Friday" android:textSize="20sp" android:gravity="center" android:layout_weight="1"/>
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="@string/Saturday" android:textSize="20sp" android:gravity="center" android:layout_weight="1"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        <Button android:id="@+id/april1btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d1" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april2btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d2" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april3btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d3" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april4btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d4" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/april5btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d5" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april6btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d6" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april7btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d7" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april8btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d8" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april9btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d9" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april10btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d10" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april11btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d11" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/april12btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d12" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april13btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d13" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april14btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d14" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april15btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d15" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april16btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d16" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april17btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d17" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april18btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d18" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/april19btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d19" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april20btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d20" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april21btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d21" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april22btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d22" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april23btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d23" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april24btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d24" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april25btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d25" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/april26btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d26" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april27btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d27" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april28btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d28" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april29btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d29" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/april30btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d30" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/btnReturnToMarch"
            android:layout_width="150dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="20dp"
            android:fontFamily="@font/poppins_medium"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:layout_marginVertical="40dp"
            android:text="@string/returnPageIcon"
            android:background="#091726"
            app:backgroundTint="@null"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button
            android:id="@+id/btnToMayLayout"
            android:layout_width="150dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="40dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/nextPageIcon"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:background="#091726"
            app:backgroundTint="@null"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
    </LinearLayout>
</LinearLayout>