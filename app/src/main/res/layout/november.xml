        <Button android:id="@+id/nov25btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d25" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/nov26btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d26" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/nov27btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d27" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/nov28btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d28" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/nov29btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d29" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/nov30btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d30" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/><TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/><TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/><TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/><TextView android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button
            android:id="@+id/btnCalendarEvents"
            android:layout_width="150dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="30dp"
            android:backgroundTint="#6B513E"
            android:fontFamily="@font/poppins_medium"
            android:text="CALENDAR EVENTS"
            android:textColor="#ffffff"
            android:textSize="16sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        <Button
            android:id="@+id/btnToDecemberLayout"
            android:layout_width="150dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="40dp"
            android:backgroundTint="#6B513E"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/nextPageIcon"
            android:textColor="#ffffff"
            android:textSize="16sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>
</LinearLayout>