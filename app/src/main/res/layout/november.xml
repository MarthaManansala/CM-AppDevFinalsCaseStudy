        <Button android:id="@+id/nov12btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d12" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/nov13btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d13" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
