        <Button android:id="@+id/nov15btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d15" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/nov16btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d16" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/nov17btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d17" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/nov18btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d18" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/nov19btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d19" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
        <Button android:id="@+id/nov20btn" android:layout_width="0dp" android:layout_height="70dp" android:layout_weight="1" android:text="@string/d20" android:background="?android:attr/selectableItemBackground" android:textColor="@color/black"/>
